{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            cq.device_id,\n            d.serial_number,\n            cq.fetched as \"fetched!\",\n            cq.canceled as \"canceled!\",\n            cr.response as \"response?\"\n        FROM command_queue cq\n        JOIN device d ON d.id = cq.device_id\n        LEFT JOIN command_response cr ON cr.command_id = cq.id\n        WHERE cq.bundle = $1\n        ",
