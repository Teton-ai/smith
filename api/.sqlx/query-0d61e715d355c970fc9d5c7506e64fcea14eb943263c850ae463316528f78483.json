  "query": "\n        SELECT\n            dni.priority,\n            n.ssid,\n            n.name,\n            n.password\n        FROM device_network_intent dni\n        JOIN network n ON n.id = dni.network_id\n        WHERE dni.device_id = $1\n        ORDER BY dni.priority ASC\n        ",
