{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    n.id,\n                    n.network_type::TEXT as \"network_type\",\n                    n.is_network_hidden,\n                    n.ssid,\n                    n.name,\n                    n.description,\n                    n.password\n                FROM network n\n                JOIN device d ON n.id = d.current_network_id\n                WHERE d.serial_number = ANY($1)\n                ",
