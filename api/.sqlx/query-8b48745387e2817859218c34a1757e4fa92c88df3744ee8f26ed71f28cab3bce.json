{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT n.id as network_id, n.ssid, n.name, n.password,\n               dcn.is_active, dcn.updated_at\n        FROM device_configured_network dcn\n        JOIN network n ON n.id = dcn.network_id\n        WHERE dcn.device_id = $1\n        ORDER BY n.name\n        ",
